{
  "name": "Hugo Site",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "latest"
    }
  },
  "forwardPorts": [1313],
  "postCreateCommand": "git submodule update --init --recursive",
  "customizations": {
    "vscode": {
      "extensions": [
        "budparr.language-hugo-vscode",
        "eliostruyf.vscode-front-matter"
      ]
    }
  }
}
